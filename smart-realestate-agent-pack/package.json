{
  "name": "smart-realestate-agent-pack",
  "version": "0.1.0",
  "private": true,
  "description": "Scaffold for a smart real estate marketing agent integrated with Claude Code, Canva, Nano Banana and Shotstack.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/api/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/api/server.js",
    "check": "tsc --noEmit",
    "create-ad": "tsx src/scripts/create-ad.ts",
    "test": "node --test dist/tests/**/*.test.js"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}

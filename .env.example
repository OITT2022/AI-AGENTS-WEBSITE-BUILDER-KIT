# Database
# For Neon:   postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# For Aurora: postgresql://postgres:pass@cluster-xxx.region.rds.amazonaws.com:5432/realestate_marketing?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/realestate_marketing
DB_PROVIDER=neon
# DB_PROVIDER=pg  ← switch to this for Aurora/RDS
REDIS_URL=redis://localhost:6379

# Existing website export API

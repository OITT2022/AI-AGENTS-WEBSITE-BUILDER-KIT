{
  "version": 2,
  "builds": [
    { "src": "api/index.ts", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/dashboard/(.+\\..*)", "dest": "/public/$1" },
    { "src": "/dashboard/?", "dest": "/public/index.html" },
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "src": "^/$", "dest": "/api/index.ts" }
  ]
}
